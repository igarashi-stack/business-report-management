# ========== 運用方針 ==========
# 本アプリは「共用の Web（HTTPS の本番 URL）」での利用を主とします（Vercel / Azure App Service 等にデプロイ）。
# ローカル（npm run dev）は開発・検証用です。
# Entra ID のリダイレクト URI には本番 URL を必ず登録し、開発時は必要に応じて localhost も追加してください。

# 開発のみ: ブラウザから X-Dev-Impersonate-User-Id を送り、別ユーザーの ID でアプリ上の「自分」を差し替え（テスト用）。
# 原則として本番では無効にすること。どうしても本番で使う場合は「管理者IDを固定」して安全弁を入れること。
# NEXT_PUBLIC_ALLOW_DEV_IMPERSONATION=true
# 本番ビルドでどうしても必要な場合のみ（危険）:
# ALLOW_DEV_IMPERSONATION=true
#
# 本番で有効化する場合（管理者のみ）:
# - ALLOW_DEV_IMPERSONATION=true
# - IMPERSONATION_ADMIN_AAD_ID=（五十嵐祐太の Azure AD オブジェクト ID）

# 開発のみ: POST /api/dev/seed-dummy-reports でダミー日報を SharePoint に投入（本番では使わない）
# ALLOW_DEV_SEED=true
# 投入する日報のうち「提出先＝五十嵐」用の Azure AD オブジェクト ID（未設定なら画面 /dev/seed-dummy で入力）
# SEED_IGARASHI_AAD_ID=

# Azure AD アプリ登録（SPA）
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_TENANT_ID=common
# リダイレクト URI（末尾スラッシュなし）: 共用本番 URL を設定。ローカル開発では localhost を使う場合、Entra に両方登録。
# 本番例: NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=https://your-app.azurewebsites.net
# Vercel 例（Production の URL と一致）: NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=https://your-project.vercel.app
NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=http://localhost:3000

# Microsoft Graph 用（委任された権限でアクセストークンに含めるスコープ。必要に応じて追加）
NEXT_PUBLIC_GRAPH_SCOPES="User.Read Sites.ReadWrite.All User.ReadBasic.All"

# ========== SharePoint 連携（必須） ==========
# 1) Azure ポータル → アプリ登録 → 認証: シングルページアプリケーション、リダイレクト URI を .env の NEXT_PUBLIC_AZURE_AD_REDIRECT_URI と一致させる
# 2) API の権限: 委任済みに User.Read, User.ReadBasic.All, Sites.ReadWrite.All を追加し「管理者の同意」
# 3) SharePoint で「業務報告書」「業務指示書」カスタムリストを作成し、下記「列とプログラムの対応」どおり列を追加
# 4) Graph のサイト ID: SharePoint サイトの URL から Graph Explorer 等で
#    GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{path} で id を取得
#    またはサイト設定 → サイト情報 → サイト ID（形式: hostname,guid1,guid2）
# 5) 各リストの設定画面 URL に含まれる List= の GUID、または Graph の .../lists で id を確認
# 6) 接続確認: 本番 URL または next dev 時に、ブラウザでログインした状態で GET /api/sharepoint/health
#    （開発時は /dev/seed-dummy の「SharePoint 接続確認」からも実行可）
# 7) Field '…' is not recognized / Unicode 推測の内部名が違う: 同ページの「業務報告書リストの列を取得」または
#    GET /api/sharepoint/columns?list=daily （list=instructions で指示書）→ envLines を .env.local に反映

# SharePoint: Graph のサイト ID（例: contoso.sharepoint.com, GUID1, GUID2）
SHAREPOINT_SITE_ID=

# 各リスト ID（ここには必ずリストの GUID を入れる）
SHAREPOINT_LIST_DAILY_REPORTS_ID=
SHAREPOINT_LIST_WORK_INSTRUCTIONS_ID=
# 任意: アプリユーザー（権限）リスト。現行の日報・指示書 API では参照しない。未設定でよい。
SHAREPOINT_LIST_APP_USERS_ID=

# ========== SharePoint 列とプログラムの対応（スクリーンショットの項目名どおり） ==========
#
# 【業務報告書】推奨リスト名: 業務報告書 など
#   タイトル     → Title（標準）
#   名前         → 記入者の Azure AD オブジェクト ID
#   提出先       → 単一行テキスト（提出先ユーザーの Azure AD オブジェクト ID）※必須・通知に使用
#   報告日       → 日付
#   勤務形態     → 単一行テキスト（出社 / リモート / 直行。未設定時は出社）
#   出社時間     → 単一行テキスト（HH:mm。6:00〜26:00・15分単位でUIから選択）
#   退勤時間     → 単一行テキスト（HH:mm。翌日深夜まで 24:00〜26:00 の30時間表記も可）
#   休憩時間     → 数値（時間。未設定時は 1 時間扱い。タスク合計から差し引いた実稼働を勤務時間に保存）
#   勤務時間     → 数値（実稼働・時間単位。UI ではタスク合計 − 休憩）
#   本日の業務内容 → 複数行テキスト（タスク配列の JSON）
#   現在の手持ち案件 / 明日の作業予定 / 備考 → 複数行テキスト
#   ※曜日は保存せず、報告日から自動計算します。
#
# 【業務指示書】推奨リスト名: 業務指示書
#   タイトル / 管理者名 / 従業員名 → テキスト（作成者・宛先は Azure ID を保存。「管理者名」は列名のままで可）
#   対象日       → 日付
#   勤務時間     → 出社 / リモート / 直行（単一行テキスト、または選択列なら各値を追加。アプリは「出社」「リモート」「直行」で保存）
#   業務内容     → 複数行（JSON: { linkedReportId, projects: [...] }）
#   備考         → 複数行
#
# Graph の field 名は「列の内部名」です（表示名と違うことが多い）。
#
# --- 例: Field '名前' is not recognized ---
# 業務報告書リストで「名前」列を追加しても、内部名は「名前」にならないことがほとんどです。
# web/.env.local に次を追加し、値だけ実際の内部名に差し替えてください（dev サーバー再起動）。
#   SHAREPOINT_DR_FIELD_USER_ID=ここに内部名
# 内部名の見つけ方:
#   SharePoint → 業務報告書リスト → 歯車「リストの設定」→「名前」列をクリック
#   → ブラウザのアドレスバーに ...?Field=◯◯◯ と出る ◯◯◯ が内部名（URL デコードされた値を .env に書く）
# Graph で一括確認: GET .../sites/{siteId}/lists/{listId}/columns?$select=name,displayName
#   → displayName が「名前」「提出先」などと一致する行の name をコピーする。
#
# 提出先など別列でも同様に Field '…' is not recognized なら、対応する SHAREPOINT_DR_FIELD_* を設定。
#
# 日報・指示書で Field '…' is not recognized となるときは、SharePoint で
# リストの設定 → 列をクリック → URL の Field= が内部名。または columns API で name を確認。
#
# 任意: 日報・指示書の内部名を .env に明示（未設定時は日本語表示名を既定に使用）
# SHAREPOINT_DR_FIELD_SUBMISSION_TARGET=
# SHAREPOINT_DR_FIELD_USER_ID=
# SHAREPOINT_DR_FIELD_REPORT_DATE=
# SHAREPOINT_DR_FIELD_WORK_STYLE=      （既定表示名: 勤務形態・日報の出社/テレ/直行）
# SHAREPOINT_DR_FIELD_CLOCK_IN=        （既定表示名: 出社時間）
# SHAREPOINT_DR_FIELD_CLOCK_OUT=       （既定表示名: 退勤時間）
# SHAREPOINT_DR_FIELD_BREAK_HOURS=     （既定表示名: 休憩時間）
# （他 DR_/WI_ も同様。listItems.ts の spField 引数を参照）
